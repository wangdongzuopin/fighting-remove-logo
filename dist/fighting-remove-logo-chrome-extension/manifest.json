{
  "manifest_version": 3,
  "name": "小蜜蜂水印去除工具",
  "version": "1.0.0",
  "description": "在 Chrome 扩展中上传图片、框选水印区域并导出处理结果。",
  "permissions": [
    "tabs"
  ],
  "action": {
    "default_title": "小蜜蜂水印去除工具",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
